# Firebase credentials — find these in Firebase Console → Project settings → Your apps
# These are intentionally public (baked into the JS bundle at build time).
# Security is enforced by Firestore Security Rules, not by keeping these secret.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to use Firebase emulators (Auth on :9099, Firestore on :8080)
VITE_USE_FIREBASE_EMULATOR=false
